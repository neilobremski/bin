#!/usr/bin/env python3
"""transcribe — CLI muscle for audio transcription via Groq Whisper API.

Usage:
    transcribe <file>                # transcribe a local audio file
    transcribe --url <download_url>  # download from URL first, then transcribe

Supported formats: m4a, mp3, wav, ogg, webm, flac, mp4
Output: plain text transcript to stdout. Errors to stderr.

Secrets resolved via local-secret:
    GROQ_API_KEY
"""
import argparse
import json
import os
import subprocess
import sys
import tempfile
import urllib.request
import urllib.error

GROQ_TRANSCRIPTION_URL = "https://api.groq.com/openai/v1/audio/transcriptions"
GROQ_MODEL = "whisper-large-v3"
SUPPORTED_EXTENSIONS = {".m4a", ".mp3", ".wav", ".ogg", ".webm", ".flac", ".mp4"}
# Groq API file size limit: 25 MB. Split threshold slightly lower for safety.
MAX_FILE_SIZE = 25 * 1024 * 1024
CHUNK_THRESHOLD = 20 * 1024 * 1024  # split files larger than 20 MB
CHUNK_DURATION_SECS = 600  # 10-minute chunks


def get_api_key():
    """Resolve GROQ_API_KEY from environment or local-secret."""
    key = os.environ.get("GROQ_API_KEY", "")
    if key:
        return key.strip()

    # Try local-secret CLI
    try:
        result = subprocess.run(
            ["local-secret", "GROQ_API_KEY"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass

    # Direct file fallback
    path = os.path.expanduser("~/lib/groq-api-key.txt")
    if os.path.isfile(path):
        with open(path) as f:
            return f.read().strip()

    return ""


def download_url(url):
    """Download a URL to a temp file. Returns path or None."""
    if not url.startswith("https://"):
        print(f"error: refusing non-HTTPS URL: {url}", file=sys.stderr)
        return None
    # Guess extension from URL
    ext = ".m4a"
    for e in SUPPORTED_EXTENSIONS:
        if e in url.lower():
            ext = e
            break

    fd, tmp_path = tempfile.mkstemp(suffix=ext, prefix="transcribe-")
    os.close(fd)

    try:
        req = urllib.request.Request(url)
        req.add_header("User-Agent", "Organism-Transcribe/1.0")
        with urllib.request.urlopen(req, timeout=120) as resp:
            data = resp.read()
        with open(tmp_path, "wb") as f:
            f.write(data)
        size_mb = len(data) / (1024 * 1024)
        print(f"Downloaded {size_mb:.1f} MB -> {tmp_path}", file=sys.stderr)
        return tmp_path
    except Exception as e:
        print(f"error: download failed: {e}", file=sys.stderr)
        try:
            os.remove(tmp_path)
        except OSError:
            pass
        return None


def split_audio(audio_path, chunk_secs=CHUNK_DURATION_SECS):
    """Split an audio file into chunks using ffmpeg. Returns list of temp file paths."""
    chunk_dir = tempfile.mkdtemp(prefix="transcribe-chunks-")
    ext = os.path.splitext(audio_path)[1] or ".m4a"
    pattern = os.path.join(chunk_dir, f"chunk_%03d{ext}")

    try:
        result = subprocess.run(
            ["ffmpeg", "-i", audio_path, "-f", "segment",
             "-segment_time", str(chunk_secs), "-c", "copy", pattern],
            capture_output=True, text=True, timeout=120
        )
        if result.returncode != 0:
            print(f"error: ffmpeg split failed: {result.stderr[:200]}", file=sys.stderr)
            return []
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        print(f"error: ffmpeg not available: {e}", file=sys.stderr)
        return []

    chunks = sorted(
        os.path.join(chunk_dir, f) for f in os.listdir(chunk_dir)
        if f.startswith("chunk_")
    )
    print(f"split into {len(chunks)} chunks", file=sys.stderr)
    return chunks


def transcribe_chunked(audio_path, api_key):
    """Split a large audio file and transcribe each chunk. Returns combined transcript."""
    import shutil
    chunks = split_audio(audio_path)
    if not chunks:
        return None

    chunk_dir = os.path.dirname(chunks[0])
    try:
        transcripts = []
        for i, chunk_path in enumerate(chunks):
            chunk_size = os.path.getsize(chunk_path)
            if chunk_size > MAX_FILE_SIZE:
                print(f"warning: chunk {i} is {chunk_size/(1024*1024):.1f} MB (over 25 MB), skipping", file=sys.stderr)
                continue
            print(f"transcribing chunk {i+1}/{len(chunks)} ({chunk_size/(1024*1024):.1f} MB)", file=sys.stderr)
            text = transcribe_single(chunk_path, api_key)
            if text:
                transcripts.append(text)
        return " ".join(transcripts) if transcripts else None
    finally:
        shutil.rmtree(chunk_dir, ignore_errors=True)


def transcribe_single(audio_path, api_key):
    """Transcribe a single audio file (must be under 25MB) via Groq Whisper API."""
    ext = os.path.splitext(audio_path)[1].lower()
    if ext not in SUPPORTED_EXTENSIONS:
        print(f"warning: extension {ext} may not be supported", file=sys.stderr)

    # Build multipart/form-data request (stdlib only)
    import uuid
    boundary = f"----KnobertTranscribe{uuid.uuid4().hex[:16]}"
    filename = os.path.basename(audio_path)

    # Map extensions to MIME types
    mime_map = {
        ".m4a": "audio/mp4", ".mp3": "audio/mpeg", ".wav": "audio/wav",
        ".ogg": "audio/ogg", ".webm": "audio/webm", ".flac": "audio/flac",
        ".mp4": "audio/mp4",
    }
    content_type = mime_map.get(ext, "application/octet-stream")

    with open(audio_path, "rb") as f:
        file_data = f.read()

    # Construct multipart body
    parts = []

    # file field
    parts.append(f"--{boundary}\r\n".encode())
    parts.append(f'Content-Disposition: form-data; name="file"; filename="{filename}"\r\n'.encode())
    parts.append(f"Content-Type: {content_type}\r\n\r\n".encode())
    parts.append(file_data)
    parts.append(b"\r\n")

    # model field
    parts.append(f"--{boundary}\r\n".encode())
    parts.append(b'Content-Disposition: form-data; name="model"\r\n\r\n')
    parts.append(f"{GROQ_MODEL}\r\n".encode())

    # response_format field
    parts.append(f"--{boundary}\r\n".encode())
    parts.append(b'Content-Disposition: form-data; name="response_format"\r\n\r\n')
    parts.append(b"text\r\n")

    # closing boundary
    parts.append(f"--{boundary}--\r\n".encode())

    body = b"".join(parts)

    req = urllib.request.Request(
        GROQ_TRANSCRIPTION_URL,
        data=body,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": f"multipart/form-data; boundary={boundary}",
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            result = resp.read().decode("utf-8")
        return result.strip()
    except urllib.error.HTTPError as e:
        error_body = e.read().decode(errors="replace")[:500]
        print(f"error: Groq API HTTP {e.code}: {error_body}", file=sys.stderr)
        return None
    except Exception as e:
        print(f"error: Groq API request failed: {e}", file=sys.stderr)
        return None


def transcribe_file(audio_path, api_key):
    """Transcribe an audio file — splits into chunks if over 20MB."""
    if not os.path.isfile(audio_path):
        print(f"error: file not found: {audio_path}", file=sys.stderr)
        return None

    file_size = os.path.getsize(audio_path)
    if file_size == 0:
        print("error: file is empty", file=sys.stderr)
        return None
    if file_size > CHUNK_THRESHOLD:
        print(f"file is {file_size / (1024*1024):.1f} MB, splitting into chunks", file=sys.stderr)
        return transcribe_chunked(audio_path, api_key)

    return transcribe_single(audio_path, api_key)


def main():
    parser = argparse.ArgumentParser(
        prog="transcribe",
        description="Transcribe audio files via Groq Whisper API",
    )
    parser.add_argument("file", nargs="?", help="Local audio file to transcribe")
    parser.add_argument("--url", help="Download audio from URL first, then transcribe")

    args = parser.parse_args()

    if not args.file and not args.url:
        parser.print_help()
        sys.exit(1)

    api_key = get_api_key()
    if not api_key:
        print("error: GROQ_API_KEY not found (set env var or ~/lib/groq-api-key.txt)", file=sys.stderr)
        sys.exit(1)

    tmp_file = None
    audio_path = args.file

    if args.url:
        tmp_file = download_url(args.url)
        if not tmp_file:
            sys.exit(1)
        audio_path = tmp_file

    try:
        transcript = transcribe_file(audio_path, api_key)
        if transcript:
            print(transcript)
        else:
            sys.exit(1)
    finally:
        if tmp_file:
            try:
                os.remove(tmp_file)
            except OSError:
                pass


if __name__ == "__main__":
    main()
