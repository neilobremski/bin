#!/usr/bin/env bash
# local-secret — Resolve a secret from environment or file.
#
# Usage: local-secret <NAME>
#
# Checks $NAME environment variable first.
# Falls back to ~/lib/<name-lowercased-with-hyphens>.txt
#
# Examples:
#   local-secret GAS_BRIDGE_KEY    # $GAS_BRIDGE_KEY or ~/lib/gas-bridge-key.txt
#   local-secret GAS_BRIDGE_URL    # $GAS_BRIDGE_URL or ~/lib/gas-bridge-url.txt
#   local-secret MQTT_PASS         # $MQTT_PASS or ~/lib/mqtt-pass.txt

set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: local-secret <NAME>" >&2
  exit 1
fi

name="$1"

# Check environment variable first
val="${!name:-}"
if [ -n "$val" ]; then
  echo "$val"
  exit 0
fi

# Convert NAME_LIKE_THIS to name-like-this.txt
file=$(echo "$name" | tr '[:upper:]_' '[:lower:]-')
path="$HOME/lib/$file.txt"

if [ -f "$path" ]; then
  cat "$path" | tr -d '\n'
  exit 0
fi

echo "error: $name not found (env or $path)" >&2
exit 1
