#!/usr/bin/env bash
# llm
#
# Lightweight CLI wrapper around `ollama run` for prompt-oriented local LLM calls.
#
# What this script does:
# - Accepts prompt input from either command arguments, stdin, or both.
# - Runs `ollama run` with a default model (`qwen3.5`) and streaming output.
# - Optionally shows a live one-line gray preview of generated text on stderr.
# - Preserves the model process exit code as this script's exit code.
#
# Input behavior and precedence:
# - If `-p/--prompt` is NOT provided:
#   - Reads stdin when piped.
#   - Uses stdin content as the full prompt.
# - If `-p/--prompt` IS provided and stdin is also piped:
#   - Uses stdin content as context (equivalent to `-c` content).
# - If neither stdin nor `-p` provides text:
#   - Sends an empty prompt to the model.
#
# Arguments:
# - `-p, --prompt <text>`  Prompt text.
# - `-t, -type, --type`    Response type: `list` or `bool`.
# - `-i, -instruction`     Instruction text used to frame the prompt.
# - `-c, -context <file>`  Read context from file and wrap in <Context> tags.
# - `-e, -echo`            Echo final prompt to stdout before model output.
# - `--preview`            Show a truncated (80 chars) live preview on stderr.
# - `-s, --silent`         Suppress passthrough of ollama stderr.
#
# Notes:
# - Streaming is handled through a FIFO to keep stdout clean while preview updates.
# - Temporary files/FIFO are cleaned up automatically via trap on exit.
# - Unknown flags are ignored by the parser as currently implemented.
#
# Examples:
# - llm -p "Summarize this note"
# - echo "Explain this code:" | llm
# - cat context.txt | llm -p "Refine this draft" --preview
# - llm --silent "Quick answer"
MODEL="qwen3.5"
prompt=""
prompt_flag=false
use_preview=false
silent=false
echo_prompt=false
response_type=""
instruction=""
context_file=""
context=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -p|--prompt)
            prompt="$2"
            prompt_flag=true
            shift 2
            ;;
        -t|-type|--type)
            response_type="$2"
            shift 2
            ;;
        -i|-instruction|--instruction)
            instruction="$2"
            shift 2
            ;;
        -c|-context|--context)
            context_file="$2"
            shift 2
            ;;
        -e|-echo|--echo)
            echo_prompt=true
            shift
            ;;
        --preview)
            use_preview=true
            shift
            ;;
        -s|--silent)
            silent=true
            shift
            ;;
        [!-./]*)
            if [ -z "$prompt" ]; then
                prompt="$1"
            fi
            shift
            ;;
        *)
            shift
            ;;
    esac
done

# Read stdin content with mode-dependent behavior.
stdin_content=""
stdin_context=""
if [ "$prompt_flag" = true ]; then
    # -p was explicitly provided: piped stdin becomes context payload.
    if [ ! -t 0 ]; then
        stdin_context=$(cat)
    fi
elif [ -z "$prompt" ]; then
    # No prompt argument provided: read stdin into prompt.
    if [ ! -t 0 ]; then
        stdin_content=$(cat)
    fi
fi

# Combine inputs appropriately
if [ -z "$prompt" ]; then
    # No prompt argument: use stdin.
    prompt="$stdin_content"
fi

# Load context from file and/or stdin into an XML-like envelope for prompt injection.
context_payload=""
if [ -n "$context_file" ]; then
    if [ ! -f "$context_file" ]; then
        echo "Context file not found: $context_file" >&2
        exit 2
    fi

    context_payload=$(cat "$context_file")
fi

if [ -n "$stdin_context" ]; then
    if [ -n "$context_payload" ]; then
        context_payload="${stdin_context}
${context_payload}"
    else
        context_payload="$stdin_context"
    fi
fi

if [ -n "$context_payload" ]; then
    context="<Memories>
${context_payload}
</Memories>"
fi

# Apply instruction framing when both response type and instruction are provided.
if [ -n "$response_type" ] && [ -n "$instruction" ]; then
    prefix=""
    suffix=""

    case "$response_type" in
        bash)
            prefix="Answer ONLY with the bash command, no explanation. "
            suffix=". Answer ONLY with the bash command, no explanation"
            ;;
        bool)
            prefix="Answer ONLY YES or NO. "
            suffix="? Answer ONLY YES or NO"
            ;;
        list)
            prefix="Answer ONLY with a list of items, one per line. "
            suffix=". Answer ONLY with a list of items, one per line"
            ;;
        *)
            echo "Invalid type: $response_type" >&2
            exit 2
            ;;
    esac

    prompt="INSTRUCTION: ${prefix}${instruction}:

${prompt}
${context}
${instruction}: <Prompt>${prompt}</Prompt>${suffix}"
fi

# If no response type is specified but context exists, sandwich context with prompt.
if [ -z "$response_type" ] && [ -n "$context" ]; then
    prompt="${prompt}
${context}
${prompt}"
fi

# Optional debug output of the fully assembled prompt.
if [ "$echo_prompt" = true ]; then
    printf '%s\n' "$prompt"
fi

# Show preview if requested
if [ "$use_preview" = true ]; then
    initial_preview="${prompt%%$'\n'*}"
    suffix=""
    if ((${#initial_preview} > 80)); then
        initial_preview=${initial_preview:0:80}
        suffix="..."
    fi
    printf '\r\033[K\033[0;90m%s%s\033[0m' "$initial_preview" "$suffix" >&2
fi

tmpstderr=$(mktemp)
tmpstream=$(mktemp -u)
exit_code_file=$(mktemp)
mkfifo "$tmpstream"
trap "rm -f '$tmpstderr' '$exit_code_file' '$tmpstream'" EXIT

# Stream ollama output through a FIFO so preview can update without corrupting stdout.
{
    printf '%s' "$prompt" | ollama run --think=false --hidethinking --nowordwrap $MODEL >"$tmpstream" 2>"$tmpstderr"
    echo $? > "$exit_code_file"
} &
ollama_pid=$!

if [ "$use_preview" = true ]; then
    current_line=""
    while IFS= read -r -n 1 char; do
        if [ -z "$char" ]; then
            printf '\r\033[K' >&2
            printf '%s\n' "$current_line"
            current_line=""
            continue
        fi

        current_line+="$char"
        preview=${current_line//$'\r'/}
        suffix=""
        if ((${#preview} > 80)); then
            preview=${preview:0:80}
            suffix="..."
        fi
        printf '\r\033[K\033[0;90m%s%s\033[0m' "$preview" "$suffix" >&2
    done < "$tmpstream"

    if [ -n "$current_line" ]; then
        printf '\r\033[K' >&2
        printf '%s\n' "$current_line"
    fi
    printf '\r\033[K' >&2
else
    cat "$tmpstream"
fi

wait "$ollama_pid"

exit_code=$(cat "$exit_code_file")


# Pass stderr to stderr unless silent flag is set
if [ "$silent" = false ] && [ -s "$tmpstderr" ]; then
    cat "$tmpstderr" >&2
fi

exit $exit_code
