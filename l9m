#!/usr/bin/env bash
echo `# <#` >/dev/null

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec python3 "$SCRIPT_DIR/apps/l9m/l9m.py" "$@"
#> > $null

$ScriptPath = $PSCommandPath
if (-not $ScriptPath) { $ScriptPath = $MyInvocation.MyCommand.Path }
if (-not $ScriptPath) { $ScriptPath = Join-Path (Get-Location) "l9m" }

$ScriptDir = Split-Path -Parent $ScriptPath
$L9mPath = Join-Path $ScriptDir "apps/l9m/l9m.py"

$Python = Get-Command python3 -ErrorAction SilentlyContinue
if ($Python) { & $Python.Source $L9mPath @args; exit $LASTEXITCODE }
$Python = Get-Command python -ErrorAction SilentlyContinue
if ($Python) { & $Python.Source $L9mPath @args; exit $LASTEXITCODE }
$Python = Get-Command py -ErrorAction SilentlyContinue
if ($Python) { & $Python.Source -3 $L9mPath @args; exit $LASTEXITCODE }

Write-Error "Could not find python3, python, or py on PATH."
exit 127
