#!/usr/bin/env bash
# memory — CLI for the hippocampus (memory organ).
# Store and recall memories. The hippocampus owns memory.db;
# this CLI provides the interface.
set -euo pipefail

DB="${MEMORY_DB:-$PWD/organs/hippocampus/memory.db}"

usage() {
  echo "Usage:"
  echo "  memory store \"content\"                    # store a memory"
  echo "  memory store -i 8 \"content\"               # store with importance (1-10)"
  echo "  memory store -c category \"content\"         # store with category"
  echo "  memory search \"query\"                     # search memories (FTS5)"
  echo "  memory recent [count]                     # show recent memories"
  echo "  memory stats                              # memory statistics"
  exit 1
}

[ $# -lt 1 ] && usage
cmd="$1"; shift

case "$cmd" in
  store)
    importance=5
    category="general"

    # Parse flags
    while [ $# -gt 0 ]; do
      case "$1" in
        -i) importance="$2"; shift 2 ;;
        -c) category="$2"; shift 2 ;;
        *)  break ;;
      esac
    done

    content="$*"
    [ -z "$content" ] && { echo "memory store: need content" >&2; exit 1; }

    # Validate importance is a number 1-10
    if ! echo "$importance" | grep -qE '^[0-9]+$' || [ "$importance" -lt 1 ] || [ "$importance" -gt 10 ]; then
      echo "memory store: importance must be 1-10" >&2; exit 1
    fi

    # Validate category is alphanumeric
    if ! echo "$category" | grep -qE '^[a-zA-Z0-9_-]+$'; then
      echo "memory store: invalid category" >&2; exit 1
    fi

    # Send stimulus to hippocampus (check >= 10 before >= 8)
    if command -v stimulus >/dev/null 2>&1; then
      if [ "$importance" -ge 10 ]; then
        stimulus send hippocampus "remember critical: $content" 2>/dev/null || true
      elif [ "$importance" -ge 8 ]; then
        stimulus send hippocampus "remember important: $content" 2>/dev/null || true
      else
        stimulus send hippocampus "remember ${category}: $content" 2>/dev/null || true
      fi
    fi

    # Also store directly if we have DB access (same body part = fast path)
    if [ -f "$DB" ]; then
      python3 -c "
import sqlite3, hashlib, sys
from datetime import datetime, timezone

db = sqlite3.connect('$DB')
content = sys.argv[1]
importance = int(sys.argv[2])
category = sys.argv[3]
h = hashlib.sha256(content.encode()).hexdigest()[:16]
now = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
db.execute('INSERT OR IGNORE INTO memories(content,importance,category,created_at,accessed_at,access_count,content_hash) VALUES(?,?,?,?,?,0,?)',
    (content, importance, category, now, now, h))
db.commit()
db.close()
" "$content" "$importance" "$category"
      echo "stored"
    else
      echo "queued (hippocampus will process next cycle)"
    fi
    ;;

  search)
    [ $# -lt 1 ] && { echo "memory search: need query" >&2; exit 1; }
    query="$*"
    if [ ! -f "$DB" ]; then
      echo "memory search: no database at $DB" >&2; exit 1
    fi
    python3 -c "
import sqlite3, sys
db = sqlite3.connect('$DB')
q = sys.argv[1]
if not q.strip():
    sys.exit(0)
rows = db.execute('''
    SELECT m.content, m.importance, m.category, m.created_at
    FROM memories_fts fts
    JOIN memories m ON m.id = fts.rowid
    WHERE memories_fts MATCH ?
    ORDER BY rank LIMIT 10
''', (q,)).fetchall()
for r in rows:
    print('\t'.join(str(c) for c in r))
db.close()
" "$query"
    ;;

  recent)
    count="${1:-10}"
    # Validate count is a number
    if ! echo "$count" | grep -qE '^[0-9]+$'; then
      echo "memory recent: count must be a number" >&2; exit 1
    fi
    if [ ! -f "$DB" ]; then
      echo "memory recent: no database at $DB" >&2; exit 1
    fi
    python3 -c "
import sqlite3, sys
db = sqlite3.connect('$DB')
rows = db.execute('SELECT content, importance, category, created_at FROM memories ORDER BY created_at DESC LIMIT ?', (int(sys.argv[1]),)).fetchall()
for r in rows:
    print('\t'.join(str(c) for c in r))
db.close()
" "$count"
    ;;

  stats)
    if [ ! -f "$DB" ]; then
      echo "memory stats: no database at $DB" >&2; exit 1
    fi
    python3 -c "
import sqlite3
db = sqlite3.connect('$DB')
total = db.execute('SELECT COUNT(*) FROM memories').fetchone()[0]
avg = db.execute('SELECT ROUND(AVG(importance),1) FROM memories').fetchone()[0]
cats = db.execute('SELECT category, COUNT(*) FROM memories GROUP BY category ORDER BY COUNT(*) DESC').fetchall()
print(f'Total: {total} memories')
print(f'Avg importance: {avg}')
print('Categories:')
for c, n in cats:
    print(f'  {c}: {n}')
db.close()
"
    ;;

  *)
    usage
    ;;
esac
