#!/usr/bin/env bash
# circ-put — Store a payload in the circulatory system.
# Returns a content-addressed reference (SHA-256 hash prefix).
#
# Usage: circ-put <file>
#        echo "data" | circ-put -
#
# Backends (set CIRC_BACKEND):
#   local  — filesystem at CIRC_DIR (default: ~/.life/circ)
#   drive  — Google Drive via GAS bridge

set -euo pipefail

BACKEND="${CIRC_BACKEND:-local}"
LOCAL_DIR="${CIRC_DIR:-$HOME/.life/circ}"

if [ $# -lt 1 ]; then
  echo "Usage: circ-put <file>  or  echo data | circ-put -" >&2
  exit 1
fi

input="$1"
if [ "$input" = "-" ]; then
  input=$(mktemp)
  cat > "$input"
  trap "rm -f '$input'" EXIT
fi

[ -f "$input" ] || { echo "error: file not found: $input" >&2; exit 1; }

hash=$(sha256sum "$input" | cut -c1-16)

case "$BACKEND" in
  local)
    mkdir -p "$LOCAL_DIR"
    [ -f "$LOCAL_DIR/$hash" ] || cp "$input" "$LOCAL_DIR/$hash"
    ;;

  drive)
    python3 -c "
import sys, base64
sys.path.insert(0, '${KNOBERT_LIB:-$HOME/knobert/lib}')
from gas_bridge import GASBridge
bridge = GASBridge()
# Check if already uploaded
existing = bridge._call('drive.list', query=\"name = 'circ-$hash'\", count=1)
if existing.get('files'):
    sys.exit(0)  # already exists, dedup
with open('$input', 'rb') as f:
    data = base64.b64encode(f.read()).decode()
mime = '$(file -b --mime-type "$input" 2>/dev/null || echo application/octet-stream)'
bridge._call('drive.upload', name='circ-$hash', mimeType=mime, data_base64=data)
" 2>/dev/null
    ;;

  *) echo "error: unknown CIRC_BACKEND=$BACKEND" >&2; exit 1 ;;
esac

echo "$hash"
