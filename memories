#!/usr/bin/env python3
"""memories — CLI for the hippocampus (memory organ).

Store and recall memories. The hippocampus owns memory.db;
this CLI provides the interface.

Usage:
    memories store "content"
    memories store -i 8 "content"
    memories store -c category "content"
    memories search "query"
    memories recent [count]
    memories important [min_importance]
    memories stats
    memories entities              — list all entities
    memories entity <id>           — show entity detail + linked memories
"""
import argparse
import hashlib
import math
import os
import re
import sqlite3
import subprocess
import sys
from datetime import datetime, timezone

# Import from the hippocampus package to avoid duplicating scoring/entity logic.
sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), "tadpole", "organs", "hippocampus"))
from retrieval import composite_score
from entities import extract_and_link_entities, get_entity_context

DB_PATH = os.environ.get("MEMORY_DB", os.path.join(os.getcwd(), "organs", "hippocampus", "memory.db"))


def get_db():
    """Connect to memory.db with WAL mode."""
    if not os.path.isfile(DB_PATH):
        print(f"memories: no database at {DB_PATH}", file=sys.stderr)
        sys.exit(1)
    db = sqlite3.connect(DB_PATH)
    db.execute("PRAGMA journal_mode=WAL")
    return db


def _has_column(db, table, column):
    """Check if a column exists in a table."""
    cols = db.execute(f"PRAGMA table_info({table})").fetchall()
    return any(c[1] == column for c in cols)


def _has_table(db, table):
    """Check if a table exists."""
    row = db.execute(
        "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name=?",
        (table,)
    ).fetchone()
    return row[0] > 0


def cmd_store(args):
    content = " ".join(args.content).strip()
    if not content:
        print("memories store: need content", file=sys.stderr)
        sys.exit(1)

    importance = args.importance
    category = args.category

    # Validate importance
    if importance < 1 or importance > 10:
        print("memories store: importance must be 1-10", file=sys.stderr)
        sys.exit(1)

    # Validate category
    if not re.match(r'^[a-zA-Z0-9_-]+$', category):
        print("memories store: invalid category", file=sys.stderr)
        sys.exit(1)

    # Dual-write: direct DB + stimulus. The stimulus path ensures remote
    # body parts receive the memory even if this CLI can't reach the DB.
    # The hash dedup in hippocampus.py handles the double-arrival gracefully.
    try:
        if importance >= 10:
            msg = f"remember critical: {content}"
        elif importance >= 8:
            msg = f"remember important: {content}"
        else:
            msg = f"remember {category}: {content}"
        subprocess.run(
            ["stimulus", "send", "hippocampus", msg],
            capture_output=True, timeout=5
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass

    # Direct store if DB exists (fast path, same body part)
    if not os.path.isfile(DB_PATH):
        print("queued (hippocampus will process next cycle)")
        return

    db = sqlite3.connect(DB_PATH)
    db.execute("PRAGMA journal_mode=WAL")

    content_hash = hashlib.sha256(content.encode()).hexdigest()[:32]
    now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    # Check for duplicate -- bump access if exists
    existing = db.execute(
        "SELECT id, importance FROM memories WHERE content_hash = ?",
        (content_hash,)
    ).fetchone()

    if existing:
        db.execute(
            "UPDATE memories SET accessed_at = ?, access_count = access_count + 1, "
            "importance = MAX(importance, ?) WHERE id = ?",
            (now, importance, existing[0])
        )
        db.commit()
        print("exists (access bumped)")
    else:
        # Set initial difficulty and stability if v2 columns exist
        has_stability = _has_column(db, "memories", "stability_days")
        if has_stability:
            initial_difficulty = max(1.0, min(10.0, 11.0 - importance))
            db.execute(
                "INSERT INTO memories(content, importance, category, source, "
                "created_at, accessed_at, access_count, content_hash, is_active, "
                "stability_days, difficulty, tier) "
                "VALUES (?, ?, ?, ?, ?, ?, 0, ?, 1, 1.0, ?, 'hot')",
                (content, importance, category, "cli", now, now, content_hash,
                 initial_difficulty)
            )
        else:
            db.execute(
                "INSERT INTO memories(content, importance, category, source, "
                "created_at, accessed_at, access_count, content_hash, is_active) "
                "VALUES (?, ?, ?, ?, ?, ?, 0, ?, 1)",
                (content, importance, category, "cli", now, now, content_hash)
            )

        # Extract entities and build tags (Steps 8-10)
        mid = db.execute("SELECT last_insert_rowid()").fetchone()[0]
        if _has_table(db, "entities"):
            extract_and_link_entities(db, mid, content)

        db.commit()
        print("stored")

    db.close()


def cmd_search(args):
    query = " ".join(args.query).strip()
    if not query:
        print("memories search: need query", file=sys.stderr)
        sys.exit(1)

    db = get_db()
    now = datetime.now(timezone.utc)
    has_stability = _has_column(db, "memories", "stability_days")

    if has_stability:
        # v2 search: tiered, five-factor scoring
        # Stage 1: search hot tier
        hot_rows = _fts_query(db, query, tier="hot")
        all_rows = list(hot_rows)

        # Stage 2: search cold if hot didn't fill
        if len(hot_rows) < 10:
            cold_rows = _fts_query(db, query, tier="cold")
            all_rows.extend(cold_rows)

        # Fallback: untiered search if nothing found
        if not all_rows:
            all_rows = _fts_query(db, query, tier=None)

        # Re-rank with v2 composite score
        scored = []
        seen_ids = set()
        for r in all_rows:
            mid = r[0]
            if mid in seen_ids:
                continue
            seen_ids.add(mid)
            score = composite_score(
                bm25_rank=r[6],
                importance=r[2],
                created_at_str=r[4],
                access_count=r[5],
                stability_days=r[7] if len(r) > 7 else 1.0,
                total_queries=10,  # reasonable default for CLI
                now=now
            )
            scored.append((score, r))
    else:
        # v1 fallback: three-factor scoring
        try:
            rows = db.execute(
                "SELECT m.id, m.content, m.importance, m.category, m.created_at, "
                "m.access_count, rank "
                "FROM memories_fts fts JOIN memories m ON m.id = fts.rowid "
                "WHERE memories_fts MATCH ? AND m.is_active = 1 "
                "ORDER BY rank LIMIT 30",
                (query,)
            ).fetchall()
        except sqlite3.OperationalError:
            print("memories search: invalid query syntax", file=sys.stderr)
            sys.exit(1)

        scored = []
        for r in rows:
            bm25 = -r[6]
            imp = r[2] / 10.0
            created = datetime.fromisoformat(r[4].replace("Z", "+00:00"))
            age = max((now - created).total_seconds() / 86400, 0.01)
            recency = 1.0 / (1.0 + math.log(1 + age))
            score = 0.4 * bm25 + 0.35 * imp + 0.25 * recency
            scored.append((score, r))

    scored.sort(key=lambda x: -x[0])

    has_tags = _has_column(db, "memories", "tags")
    result_ids = []

    for _, r in scored[:10]:
        mid = r[0]
        result_ids.append(mid)
        # Print: content, importance, category, created_at, access_count
        line = f"{r[1]}\t{r[2]}\t{r[3]}\t{r[4]}\t{r[5]}"
        if has_tags:
            tags = db.execute("SELECT tags FROM memories WHERE id=?", (mid,)).fetchone()
            if tags and tags[0]:
                line += f"\ttags={tags[0]}"
        print(line)

    # Show entity context if entities table exists and results reference entities
    if result_ids and _has_table(db, "entities"):
        entity_context = get_entity_context(db, result_ids)
        if entity_context:
            print("\n--- Entity Context ---")
            for block in entity_context:
                print(block)

    db.close()


def _fts_query(db, query, tier=None):
    """Execute FTS5 query with optional tier filter. Returns rows with stability_days."""
    # Convert multi-word queries to OR syntax for broader matching
    words = query.strip().split()
    if len(words) > 1 and "OR" not in query and "AND" not in query and '"' not in query:
        query = " OR ".join(words)
    sql = """
        SELECT m.id, m.content, m.importance, m.category, m.created_at,
               m.access_count, rank, m.stability_days
        FROM memories_fts fts JOIN memories m ON m.id = fts.rowid
        WHERE memories_fts MATCH ? AND m.is_active = 1
    """
    params = [query]
    if tier:
        sql += " AND m.tier = ?"
        params.append(tier)
    sql += " ORDER BY rank LIMIT 30"

    try:
        return db.execute(sql, params).fetchall()
    except sqlite3.OperationalError:
        return []


def cmd_recent(args):
    db = get_db()
    rows = db.execute(
        "SELECT content, importance, category, created_at "
        "FROM memories WHERE is_active = 1 "
        "ORDER BY created_at DESC LIMIT ?",
        (args.count,)
    ).fetchall()

    for r in rows:
        print("\t".join(str(c) for c in r))

    db.close()


def cmd_important(args):
    db = get_db()
    rows = db.execute(
        "SELECT content, importance, category, created_at "
        "FROM memories WHERE is_active = 1 AND importance >= ? "
        "ORDER BY importance DESC, created_at DESC LIMIT 20",
        (args.min_importance,)
    ).fetchall()

    for r in rows:
        print("\t".join(str(c) for c in r))

    db.close()


def cmd_entities(args):
    db = get_db()
    if not _has_table(db, "entities"):
        print("no entities table (run hippocampus first)")
        db.close()
        return

    rows = db.execute(
        "SELECT id, name, entity_type, summary FROM entities ORDER BY name"
    ).fetchall()

    if not rows:
        print("no entities")
    else:
        for eid, name, etype, summary in rows:
            # Count linked memories
            count = db.execute(
                "SELECT COUNT(*) FROM entity_memories WHERE entity_id=? AND valid_until IS NULL",
                (eid,)
            ).fetchone()[0]
            print(f"{eid}\t{name}\t{etype}\t{count} memories\t{summary}")

    db.close()


def cmd_entity(args):
    db = get_db()
    if not _has_table(db, "entities"):
        print("no entities table (run hippocampus first)")
        db.close()
        return

    eid = args.entity_id
    row = db.execute(
        "SELECT id, name, aliases, entity_type, summary, properties "
        "FROM entities WHERE id=?", (eid,)
    ).fetchone()

    if not row:
        print(f"entity '{eid}' not found", file=sys.stderr)
        db.close()
        sys.exit(1)

    print(f"Entity: {row[1]} ({row[0]})")
    print(f"Type: {row[3]}")
    print(f"Aliases: {row[2]}")
    print(f"Summary: {row[4]}")

    # Show linked memories
    linked = db.execute("""
        SELECT m.id, m.content, m.importance, m.category, m.created_at
        FROM memories m
        JOIN entity_memories em ON m.id = em.memory_id
        WHERE em.entity_id = ? AND em.valid_until IS NULL AND m.is_active = 1
        ORDER BY m.importance DESC, m.created_at DESC LIMIT 20
    """, (eid,)).fetchall()

    if linked:
        print(f"\nLinked memories ({len(linked)}):")
        for mid, content, imp, cat, created in linked:
            print(f"  [{imp}] ({cat}) {content[:120]}")
    else:
        print("\nNo linked memories.")

    db.close()


def cmd_stats(args):
    db = get_db()

    total = db.execute("SELECT COUNT(*) FROM memories").fetchone()[0]
    active = db.execute(
        "SELECT COUNT(*) FROM memories WHERE is_active = 1"
    ).fetchone()[0]
    avg = db.execute(
        "SELECT ROUND(AVG(importance), 1) FROM memories WHERE is_active = 1"
    ).fetchone()[0] or 0
    cats = db.execute(
        "SELECT category, COUNT(*) FROM memories WHERE is_active = 1 "
        "GROUP BY category ORDER BY COUNT(*) DESC"
    ).fetchall()

    print(f"Total: {total} ({active} active)")
    print(f"Avg importance: {avg}")

    # v2 tier stats
    if _has_column(db, "memories", "tier"):
        hot = db.execute(
            "SELECT COUNT(*) FROM memories WHERE is_active=1 AND tier='hot'"
        ).fetchone()[0]
        cold = db.execute(
            "SELECT COUNT(*) FROM memories WHERE is_active=1 AND tier='cold'"
        ).fetchone()[0]
        print(f"Tiers: {hot} hot, {cold} cold")

    # Entity stats
    if _has_table(db, "entities"):
        ent_count = db.execute("SELECT COUNT(*) FROM entities").fetchone()[0]
        link_count = db.execute(
            "SELECT COUNT(*) FROM entity_memories WHERE valid_until IS NULL"
        ).fetchone()[0]
        print(f"Entities: {ent_count} ({link_count} links)")

    print("Categories:")
    for c, n in cats:
        print(f"  {c}: {n}")

    db.close()


def main():
    parser = argparse.ArgumentParser(
        prog="memories",
        description="CLI for the hippocampus (memory organ)."
    )
    sub = parser.add_subparsers(dest="command")

    # store
    p_store = sub.add_parser("store", help="Store a memory")
    p_store.add_argument("-i", "--importance", type=int, default=5,
                         help="Importance 1-10 (default: 5)")
    p_store.add_argument("-c", "--category", default="general",
                         help="Category (default: general)")
    p_store.add_argument("content", nargs="+", help="Memory content")

    # search
    p_search = sub.add_parser("search", help="Search memories (FTS5 + smart ranking)")
    p_search.add_argument("query", nargs="+", help="Search query")

    # recent
    p_recent = sub.add_parser("recent", help="Show recent memories")
    p_recent.add_argument("count", nargs="?", type=int, default=10,
                          help="Number of memories (default: 10)")

    # important
    p_important = sub.add_parser("important", help="Show high-importance memories")
    p_important.add_argument("min_importance", nargs="?", type=int, default=7,
                             help="Minimum importance (default: 7)")

    # stats
    sub.add_parser("stats", help="Memory statistics")

    # entities
    sub.add_parser("entities", help="List all entities")

    # entity
    p_entity = sub.add_parser("entity", help="Show entity detail + linked memories")
    p_entity.add_argument("entity_id", help="Entity ID")

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    dispatch = {
        "store": cmd_store,
        "search": cmd_search,
        "recent": cmd_recent,
        "important": cmd_important,
        "stats": cmd_stats,
        "entities": cmd_entities,
        "entity": cmd_entity,
    }
    dispatch[args.command](args)


if __name__ == "__main__":
    main()
