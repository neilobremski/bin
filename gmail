#!/usr/bin/env python3
"""gmail — CLI muscle for Gmail access.

Abstracts Gmail via GAS bridge, with automatic fallback to Gmail REST API
when the bridge is rate-limited.

Usage:
    gmail search <query> [--count N]
    gmail get <id>
    gmail reply <id> --body "text"
    gmail reply <id> --body-file <path>
    gmail label <id> --add LABEL
    gmail label <id> --remove LABEL

Secrets resolved via local-secret:
    GAS_BRIDGE_URL, GAS_BRIDGE_KEY
"""
import argparse
import base64
import json
import os
import subprocess
import sys
import tempfile
import time
import urllib.request
import urllib.error
import urllib.parse
from email.mime.text import MIMEText
from pathlib import Path


# ---------------------------------------------------------------------------
# GAS bridge helpers
# ---------------------------------------------------------------------------

def gas(*args):
    """Call the gas CLI and return parsed JSON, or None on failure."""
    try:
        result = subprocess.run(
            ["gas"] + list(args),
            capture_output=True, text=True, timeout=30
        )
        if result.returncode != 0:
            err = result.stderr.strip() + result.stdout.strip()
            # Detect rate limiting — trigger fallback
            if "too many times" in err.lower() or "quota" in err.lower():
                return _RATE_LIMITED
            return None
        return json.loads(result.stdout)
    except (FileNotFoundError, subprocess.TimeoutExpired, json.JSONDecodeError):
        return None


# Sentinel for rate-limit detection
_RATE_LIMITED = object()


# ---------------------------------------------------------------------------
# Gmail REST API fallback (direct token-based)
# ---------------------------------------------------------------------------

TOKEN_CACHE = Path.home() / ".gas" / "token.json"
GMAIL_API = "https://gmail.googleapis.com/gmail/v1/users/me"


def _get_token():
    """Return a valid access token, refreshing via gas if needed."""
    # Check cache
    if TOKEN_CACHE.exists():
        try:
            data = json.loads(TOKEN_CACHE.read_text())
            if data.get("expires_at", 0) > time.time() + 60:
                return data["access_token"]
        except (json.JSONDecodeError, KeyError):
            pass

    # Refresh via gas
    try:
        result = subprocess.run(
            ["gas", "token.get"], capture_output=True, text=True, timeout=30
        )
        if result.returncode != 0:
            return None
        data = json.loads(result.stdout)
        token = data.get("access_token") or data.get("token")
        if not token:
            return None
        # Cache it (assume 55 min lifetime if not specified)
        expires_at = data.get("expires_at", time.time() + 3300)
        TOKEN_CACHE.parent.mkdir(parents=True, exist_ok=True)
        tmp = TOKEN_CACHE.with_suffix('.tmp')
        tmp.write_text(json.dumps({
            "access_token": token,
            "expires_at": expires_at,
        }))
        tmp.rename(TOKEN_CACHE)
        return token
    except (FileNotFoundError, subprocess.TimeoutExpired, json.JSONDecodeError):
        return None


def _gmail_request(path, method="GET", body=None):
    """Make an authenticated Gmail REST API request."""
    token = _get_token()
    if not token:
        print("error: could not obtain Gmail access token", file=sys.stderr)
        return None

    url = f"{GMAIL_API}/{path}"
    headers = {
        "Authorization": f"Bearer {token}",
        "Content-Type": "application/json",
    }
    data = json.dumps(body).encode() if body else None
    req = urllib.request.Request(url, data=data, headers=headers, method=method)

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        print(f"error: Gmail API HTTP {e.code}: {e.read().decode()[:200]}", file=sys.stderr)
        return None
    except Exception as e:
        print(f"error: Gmail API: {e}", file=sys.stderr)
        return None


def _rest_search(query, count):
    """Search via Gmail REST API."""
    q = urllib.parse.quote(query)
    return _gmail_request(f"messages?q={q}&maxResults={count}")


def _rest_get(msg_id):
    """Get a message via Gmail REST API."""
    return _gmail_request(f"messages/{msg_id}?format=full")


def _rest_reply(msg_id, body_text):
    """Reply to a thread via Gmail REST API."""
    # First, get the original message for headers
    original = _gmail_request(f"messages/{msg_id}?format=metadata&metadataHeaders=Subject&metadataHeaders=From&metadataHeaders=To&metadataHeaders=Message-ID")
    if not original:
        return None

    thread_id = original.get("threadId", "")
    headers = {h["name"]: h["value"] for h in original.get("payload", {}).get("headers", [])}

    reply_to = headers.get("From", "")
    subject = headers.get("Subject", "")
    if not subject.lower().startswith("re:"):
        subject = f"Re: {subject}"
    message_id = headers.get("Message-ID", "")

    msg = MIMEText(body_text)
    msg["To"] = reply_to
    msg["Subject"] = subject
    if message_id:
        msg["In-Reply-To"] = message_id
        msg["References"] = message_id

    raw = base64.urlsafe_b64encode(msg.as_bytes()).decode()
    payload = {"raw": raw}
    if thread_id:
        payload["threadId"] = thread_id

    return _gmail_request("messages/send", method="POST", body=payload)


def _rest_label(msg_id, add=None, remove=None):
    """Modify labels via Gmail REST API."""
    body = {}
    if add:
        body["addLabelIds"] = [add]
    if remove:
        body["removeLabelIds"] = [remove]
    return _gmail_request(f"messages/{msg_id}/modify", method="POST", body=body)


# ---------------------------------------------------------------------------
# Command implementations (GAS primary, REST fallback)
# ---------------------------------------------------------------------------

def cmd_search(args):
    """Search Gmail."""
    result = gas("gmail.search", f"query={args.query}", f"count={args.count}")

    if result is _RATE_LIMITED:
        result = _rest_search(args.query, args.count)

    if not result:
        print("[]")
        return

    output(result)


def cmd_get(args):
    """Get a full email."""
    result = gas("gmail.get", f"id={args.id}")

    if result is _RATE_LIMITED:
        result = _rest_get(args.id)

    if not result:
        print("{}")
        return

    output(result)


def cmd_reply(args):
    """Reply to an email thread."""
    if args.body_file:
        try:
            body_text = Path(args.body_file).read_text()
        except Exception as e:
            print(f"error: could not read body file: {e}", file=sys.stderr)
            sys.exit(1)
    elif args.body:
        body_text = args.body
    else:
        print("error: --body or --body-file required", file=sys.stderr)
        sys.exit(1)

    # Pass body via a temp approach to avoid CLI arg size limits:
    # Write to a temp file, pass as body=@<path> (gas reads and base64-encodes,
    # but gmail.reply on the bridge expects plain text in the body field).
    # Simpler: just pass the body as a string arg for GAS bridge (it handles
    # encoding internally), but cap at 100KB to avoid OS arg limits.
    if len(body_text) > 100000:
        # Large body: fall back to REST API directly
        result = _rest_reply(args.id, body_text)
    else:
        result = gas("gmail.reply", f"id={args.id}", f"body={body_text}")
        if result is _RATE_LIMITED:
            result = _rest_reply(args.id, body_text)

    if not result:
        print('{"error": "reply failed"}', file=sys.stderr)
        sys.exit(1)

    output(result)


def cmd_label(args):
    """Add or remove a label."""
    if not args.add and not args.remove:
        print("error: --add or --remove required", file=sys.stderr)
        sys.exit(1)

    gas_args = ["gmail.label", f"id={args.id}"]
    if args.add:
        gas_args.append(f"add={args.add}")
    if args.remove:
        gas_args.append(f"remove={args.remove}")

    result = gas(*gas_args)

    if result is _RATE_LIMITED:
        result = _rest_label(args.id, add=args.add, remove=args.remove)

    if not result:
        print('{"error": "label operation failed"}', file=sys.stderr)
        sys.exit(1)

    output(result)


# ---------------------------------------------------------------------------
# Output helper
# ---------------------------------------------------------------------------

def output(data):
    """Print JSON — pretty if TTY, compact if piped."""
    if sys.stdout.isatty():
        print(json.dumps(data, indent=2))
    else:
        print(json.dumps(data))


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="gmail",
        description="Gmail CLI muscle — GAS bridge with REST API fallback",
    )
    sub = parser.add_subparsers(dest="command")

    # search
    p_search = sub.add_parser("search", help="Search emails")
    p_search.add_argument("query", help="Gmail search query")
    p_search.add_argument("--count", type=int, default=10, help="Max results")

    # get
    p_get = sub.add_parser("get", help="Get full email by ID")
    p_get.add_argument("id", help="Message or thread ID")

    # reply
    p_reply = sub.add_parser("reply", help="Reply to an email thread")
    p_reply.add_argument("id", help="Thread/message ID to reply to")
    p_reply.add_argument("--body", help="Reply body text")
    p_reply.add_argument("--body-file", help="File containing reply body")

    # label
    p_label = sub.add_parser("label", help="Manage labels on a message")
    p_label.add_argument("id", help="Message ID")
    p_label.add_argument("--add", help="Label to add")
    p_label.add_argument("--remove", help="Label to remove")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    dispatch = {
        "search": cmd_search,
        "get": cmd_get,
        "reply": cmd_reply,
        "label": cmd_label,
    }
    dispatch[args.command](args)


if __name__ == "__main__":
    main()
