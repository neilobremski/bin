#!/usr/bin/env python3
"""gmail — CLI muscle for Gmail access.

Abstracts Gmail via GAS bridge, with automatic fallback to Gmail REST API
when the bridge is rate-limited.

Usage:
    gmail search <query> [--count N]
    gmail get <id>
    gmail reply <id> --body "text" [--format markdown|plain] [--html "<html>"]
    gmail reply <id> --body-file <path> [--format markdown|plain]
    gmail send <to> --subject "text" --body "text" [--format markdown|plain]
    gmail send <to> --subject "text" --html "<html>"
    gmail label <id> --add LABEL
    gmail label <id> --remove LABEL

Secrets resolved via local-secret:
    GAS_BRIDGE_URL, GAS_BRIDGE_KEY
"""
import argparse
import base64
import json
import os
import re
import subprocess
import sys
import tempfile
import time
import urllib.request
import urllib.error
import urllib.parse
from email.mime.text import MIMEText
from pathlib import Path


# ---------------------------------------------------------------------------
# Markdown-to-HTML converter (stdlib only, covers the 80% case)
# ---------------------------------------------------------------------------

def _md_to_html(md_text):
    """Convert markdown text to HTML. Handles headers, bold, italic, links,
    code blocks, inline code, lists, paragraphs, and line breaks."""
    lines = md_text.split('\n')
    html_parts = []
    in_code_block = False
    in_ul = False
    in_ol = False
    paragraph_lines = []

    def _flush_paragraph():
        if paragraph_lines:
            text = '\n'.join(paragraph_lines)
            text = _inline_format(text)
            html_parts.append(f'<p>{text}</p>')
            paragraph_lines.clear()

    def _close_list():
        nonlocal in_ul, in_ol
        if in_ul:
            html_parts.append('</ul>')
            in_ul = False
        if in_ol:
            html_parts.append('</ol>')
            in_ol = False

    def _inline_format(text):
        """Apply inline formatting: bold, italic, links, inline code."""
        # Inline code (must come before bold/italic to avoid conflicts)
        text = re.sub(r'`([^`]+)`', r'<code>\1</code>', text)
        # Links [text](url)
        text = re.sub(r'\[([^\]]+)\]\(([^)]+)\)', r'<a href="\2">\1</a>', text)
        # Bold **text** or __text__
        text = re.sub(r'\*\*(.+?)\*\*', r'<strong>\1</strong>', text)
        text = re.sub(r'__(.+?)__', r'<strong>\1</strong>', text)
        # Italic *text* or _text_ (but not inside words with underscores)
        text = re.sub(r'(?<!\w)\*(.+?)\*(?!\w)', r'<em>\1</em>', text)
        text = re.sub(r'(?<!\w)_(.+?)_(?!\w)', r'<em>\1</em>', text)
        # Line breaks (two trailing spaces or explicit <br>)
        text = re.sub(r'  \n', '<br>\n', text)
        return text

    for line in lines:
        # Code block toggle
        if line.strip().startswith('```'):
            if in_code_block:
                html_parts.append('</code></pre>')
                in_code_block = False
            else:
                _flush_paragraph()
                _close_list()
                lang = line.strip()[3:].strip()
                cls = f' class="language-{lang}"' if lang else ''
                html_parts.append(f'<pre><code{cls}>')
                in_code_block = True
            continue

        if in_code_block:
            # Escape HTML inside code blocks
            escaped = line.replace('&', '&amp;').replace('<', '&lt;').replace('>', '&gt;')
            html_parts.append(escaped)
            continue

        stripped = line.strip()

        # Blank line — flush paragraph and close lists
        if not stripped:
            _flush_paragraph()
            _close_list()
            continue

        # Headers
        header_match = re.match(r'^(#{1,6})\s+(.+)$', stripped)
        if header_match:
            _flush_paragraph()
            _close_list()
            level = len(header_match.group(1))
            content = _inline_format(header_match.group(2))
            html_parts.append(f'<h{level}>{content}</h{level}>')
            continue

        # Unordered list item
        ul_match = re.match(r'^[-*+]\s+(.+)$', stripped)
        if ul_match:
            _flush_paragraph()
            if in_ol:
                html_parts.append('</ol>')
                in_ol = False
            if not in_ul:
                html_parts.append('<ul>')
                in_ul = True
            content = _inline_format(ul_match.group(1))
            html_parts.append(f'<li>{content}</li>')
            continue

        # Ordered list item
        ol_match = re.match(r'^\d+\.\s+(.+)$', stripped)
        if ol_match:
            _flush_paragraph()
            if in_ul:
                html_parts.append('</ul>')
                in_ul = False
            if not in_ol:
                html_parts.append('<ol>')
                in_ol = True
            content = _inline_format(ol_match.group(1))
            html_parts.append(f'<li>{content}</li>')
            continue

        # Horizontal rule
        if re.match(r'^[-*_]{3,}\s*$', stripped):
            _flush_paragraph()
            _close_list()
            html_parts.append('<hr>')
            continue

        # Regular text — accumulate for paragraph
        _close_list()
        paragraph_lines.append(stripped)

    # Flush remaining state
    if in_code_block:
        html_parts.append('</code></pre>')
    _flush_paragraph()
    _close_list()

    return '\n'.join(html_parts)


def _wrap_html_email(html_body):
    """Wrap HTML body in a clean email template with basic styling."""
    return f"""\
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  body {{
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
                 'Helvetica Neue', Arial, sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: #222;
    max-width: 640px;
    margin: 0 auto;
    padding: 20px;
  }}
  h1, h2, h3, h4, h5, h6 {{
    margin-top: 1.2em;
    margin-bottom: 0.4em;
    color: #111;
  }}
