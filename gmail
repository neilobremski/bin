  a {{ color: #1a73e8; text-decoration: none; }}
  a:hover {{ text-decoration: underline; }}
  code {{
    background: #f1f3f4;
    padding: 2px 6px;
    border-radius: 3px;
    font-family: 'SF Mono', Menlo, Consolas, monospace;
