#!/usr/bin/env python3
"""gmail — CLI muscle for Gmail access.

Abstracts Gmail via GAS bridge, with automatic fallback to Gmail REST API
when the bridge is rate-limited.

Usage:
    gmail search <query> [--count N]
    gmail get <id>
    gmail reply <id> --body "text" [--format markdown|plain] [--html "<html>"]
    gmail reply <id> --body-file <path> [--format markdown|plain]
    gmail send <to> --subject "text" --body "text" [--format markdown|plain]
    gmail send <to> --subject "text" --html "<html>"
    gmail label <id> --add LABEL
    gmail label <id> --remove LABEL

Secrets resolved via local-secret:
    GAS_BRIDGE_URL, GAS_BRIDGE_KEY
"""
import argparse
import base64
import json
import os
import re
import subprocess
import sys
import tempfile
import time
import urllib.request
import urllib.error
import urllib.parse
from email.mime.text import MIMEText
from pathlib import Path


# ---------------------------------------------------------------------------
# Mock mode — filesystem-based mailbox for testing
# ---------------------------------------------------------------------------

def _mock_dir():
    """Return Path to mock dir, or None if not in mock mode."""
    d = os.environ.get("GMAIL_MOCK_DIR")
    return Path(d) if d else None


def _mock_next_id(mock):
    """Return the next integer ID as a string, incrementing the counter."""
    id_file = mock / "next_id.txt"
    try:
        n = int(id_file.read_text().strip())
    except (FileNotFoundError, ValueError):
        n = 1
    id_file.write_text(str(n + 1) + "\n")
    return str(n)


def _mock_search(args):
    """Mock gmail search: filter inbox/*.json by query tokens."""
    mock = _mock_dir()
    inbox = mock / "inbox"
    if not inbox.is_dir():
        print("[]")
        return

    query = args.query
    results = []
    for p in sorted(inbox.glob("*.json")):
        try:
            email = json.loads(p.read_text())
        except (json.JSONDecodeError, OSError):
            continue

        labels = email.get("labels", [])

        # Filter: is:unread
        if "is:unread" in query and "UNREAD" not in labels:
            continue

        # Filter: label:X
        label_ok = True
        for m in re.finditer(r'label:(\S+)', query):
            if m.group(1) not in labels:
                label_ok = False
                break
        if not label_ok:
            continue

        results.append({
            "id": email.get("id", p.stem),
            "from": email.get("from", ""),
            "subject": email.get("subject", ""),
            "snippet": email.get("body", "")[:100],
        })

    output(results[:args.count])


def _mock_get(args):
    """Mock gmail get: read inbox/<id>.json."""
    mock = _mock_dir()
    p = mock / "inbox" / f"{args.id}.json"
    if not p.exists():
        print("{}")
        return
    try:
        email = json.loads(p.read_text())
    except (json.JSONDecodeError, OSError):
        print("{}")
        return
    output({
        "id": email.get("id", args.id),
        "from": email.get("from", ""),
        "subject": email.get("subject", ""),
        "body": email.get("body", ""),
    })


def _mock_reply(args):
    """Mock gmail reply: write to sent/, return status."""
    mock = _mock_dir()
    original_path = mock / "inbox" / f"{args.id}.json"
    try:
        original = json.loads(original_path.read_text())
    except (FileNotFoundError, json.JSONDecodeError):
        print('{"error": "original email not found"}', file=sys.stderr)
        sys.exit(1)

    if args.body_file:
        body_text = Path(args.body_file).read_text()
    elif args.body:
        body_text = args.body
    else:
        print("error: --body or --body-file required", file=sys.stderr)
        sys.exit(1)

    new_id = _mock_next_id(mock)
    sent_dir = mock / "sent"
    sent_dir.mkdir(parents=True, exist_ok=True)
    reply = {
        "id": new_id,
        "to": original.get("from", ""),
        "subject": "Re: " + original.get("subject", ""),
        "body": body_text,
        "in_reply_to": args.id,
    }
    (sent_dir / f"{new_id}.json").write_text(json.dumps(reply))
    output({"status": "sent", "id": new_id})


def _mock_send(args):
    """Mock gmail send: write to sent/, return status."""
    mock = _mock_dir()

    if args.body_file:
        body_text = Path(args.body_file).read_text()
    elif args.body:
        body_text = args.body
    else:
        print("error: --body or --body-file required", file=sys.stderr)
        sys.exit(1)

    new_id = _mock_next_id(mock)
    sent_dir = mock / "sent"
    sent_dir.mkdir(parents=True, exist_ok=True)
    email = {
        "id": new_id,
        "to": args.to,
        "subject": args.subject,
        "body": body_text,
    }
    (sent_dir / f"{new_id}.json").write_text(json.dumps(email))
    output({"status": "sent", "id": new_id})


def _mock_label(args):
    """Mock gmail label: modify labels array in inbox/<id>.json."""
    mock = _mock_dir()
    p = mock / "inbox" / f"{args.id}.json"
    try:
        email = json.loads(p.read_text())
    except (FileNotFoundError, json.JSONDecodeError):
        print('{"error": "email not found"}', file=sys.stderr)
        sys.exit(1)

    labels = email.get("labels", [])
    if args.add and args.add not in labels:
        labels.append(args.add)
    if args.remove and args.remove in labels:
        labels.remove(args.remove)
    email["labels"] = labels
    p.write_text(json.dumps(email))
    output({"status": "ok"})


# ---------------------------------------------------------------------------
# Markdown-to-HTML converter (stdlib only, covers the 80% case)
# ---------------------------------------------------------------------------

def _md_to_html(md_text):
    """Convert markdown text to HTML. Handles headers, bold, italic, links,
    code blocks, inline code, lists, paragraphs, and line breaks."""
    lines = md_text.split('\n')
    html_parts = []
    in_code_block = False
    in_ul = False
    in_ol = False
    paragraph_lines = []

    def _flush_paragraph():
        if paragraph_lines:
            text = '\n'.join(paragraph_lines)
            text = _inline_format(text)
            html_parts.append(f'<p>{text}</p>')
            paragraph_lines.clear()

    def _close_list():
        nonlocal in_ul, in_ol
        if in_ul:
            html_parts.append('</ul>')
            in_ul = False
        if in_ol:
            html_parts.append('</ol>')
            in_ol = False

    def _inline_format(text):
        """Apply inline formatting: bold, italic, links, images, inline code."""
        # Inline code (must come before bold/italic to avoid conflicts)
        text = re.sub(r'`([^`]+)`', r'<code>\1</code>', text)
        # Images ![alt](url) — must come before links
        text = re.sub(r'!\[([^\]]*)\]\(([^)]+)\)',
                       r'<img src="\2" alt="\1" style="max-width:100%;height:auto">', text)
        # Links [text](url)
        text = re.sub(r'\[([^\]]+)\]\(([^)]+)\)', r'<a href="\2">\1</a>', text)
        # Bold **text** or __text__
        text = re.sub(r'\*\*(.+?)\*\*', r'<strong>\1</strong>', text)
        text = re.sub(r'__(.+?)__', r'<strong>\1</strong>', text)
        # Italic *text* or _text_ (but not inside words with underscores)
        text = re.sub(r'(?<!\w)\*(.+?)\*(?!\w)', r'<em>\1</em>', text)
        text = re.sub(r'(?<!\w)_(.+?)_(?!\w)', r'<em>\1</em>', text)
        # Line breaks (two trailing spaces or explicit <br>)
        text = re.sub(r'  \n', '<br>\n', text)
        return text

    for line in lines:
        # Code block toggle
        if line.strip().startswith('```'):
            if in_code_block:
                html_parts.append('</code></pre>')
                in_code_block = False
            else:
                _flush_paragraph()
                _close_list()
                lang = line.strip()[3:].strip()
                cls = f' class="language-{lang}"' if lang else ''
                html_parts.append(f'<pre><code{cls}>')
                in_code_block = True
            continue

        if in_code_block:
            # Escape HTML inside code blocks
            escaped = line.replace('&', '&amp;').replace('<', '&lt;').replace('>', '&gt;')
            html_parts.append(escaped)
            continue

        stripped = line.strip()

        # Blank line — flush paragraph and close lists
        if not stripped:
            _flush_paragraph()
            _close_list()
            continue

        # Headers
        header_match = re.match(r'^(#{1,6})\s+(.+)$', stripped)
        if header_match:
            _flush_paragraph()
            _close_list()
            level = len(header_match.group(1))
            content = _inline_format(header_match.group(2))
            html_parts.append(f'<h{level}>{content}</h{level}>')
            continue

        # Unordered list item
        ul_match = re.match(r'^[-*+]\s+(.+)$', stripped)
        if ul_match:
            _flush_paragraph()
            if in_ol:
                html_parts.append('</ol>')
                in_ol = False
            if not in_ul:
                html_parts.append('<ul>')
                in_ul = True
            content = _inline_format(ul_match.group(1))
            html_parts.append(f'<li>{content}</li>')
            continue

        # Ordered list item
        ol_match = re.match(r'^\d+\.\s+(.+)$', stripped)
        if ol_match:
            _flush_paragraph()
            if in_ul:
                html_parts.append('</ul>')
                in_ul = False
            if not in_ol:
                html_parts.append('<ol>')
                in_ol = True
            content = _inline_format(ol_match.group(1))
            html_parts.append(f'<li>{content}</li>')
            continue

        # Horizontal rule
        if re.match(r'^[-*_]{3,}\s*$', stripped):
            _flush_paragraph()
            _close_list()
            html_parts.append('<hr>')
            continue

        # Regular text — accumulate for paragraph
        _close_list()
        paragraph_lines.append(stripped)

    # Flush remaining state
    if in_code_block:
        html_parts.append('</code></pre>')
    _flush_paragraph()
    _close_list()

    return '\n'.join(html_parts)


def _detect_mime(data):
    """Detect image MIME type from magic bytes. Returns type or None."""
    if data[:8] == b'\x89PNG\r\n\x1a\n':
        return 'image/png'
    if data[:3] == b'\xff\xd8\xff':
        return 'image/jpeg'
    if data[:4] in (b'GIF8',):
        return 'image/gif'
    if data[:4] == b'RIFF' and data[8:12] == b'WEBP':
        return 'image/webp'
    return None


_IMAGE_MAX_RAW = 500 * 1024      # 500 KB per image (raw bytes)
_IMAGE_TOTAL_B64 = 1024 * 1024   # 1 MB cumulative base64 budget


def _resolve_circ_images(md_text):
    """Replace ![alt](circ:HASH) with data-URI images in markdown text.

    Calls circ-get to retrieve each image, detects MIME type from magic bytes,
    base64-encodes the data, and substitutes a data URI. If retrieval or
    detection fails, the image reference is replaced with the alt text.

    Per-image limit: 500 KB raw. Total base64 budget: 1 MB. Exceeding either
    falls back to alt text with a stderr warning.

    Returns the modified markdown string.
    """
    pattern = re.compile(r'!\[([^\]]*)\]\(circ:([a-fA-F0-9]+)\)')
    matches = list(pattern.finditer(md_text))
    if not matches:
        return md_text

    circ_dir = Path(os.environ.get('CIRC_DIR', Path.home() / '.life' / 'circ'))
    result = md_text
    cumulative_b64 = 0

    for match in reversed(matches):  # reverse to preserve offsets
        alt = match.group(1)
        circ_hash = match.group(2)
        cache_path = circ_dir / circ_hash

        # Ensure the file is cached locally
        if not cache_path.exists():
            try:
                subprocess.run(
                    ['circ-get', circ_hash],
                    capture_output=True, timeout=15
                )
            except (FileNotFoundError, subprocess.TimeoutExpired):
                pass

        if not cache_path.exists():
            # Could not retrieve — replace with alt text
            print(f"gmail: warning: image circ:{circ_hash} could not be resolved (circ-get failed)", file=sys.stderr)
            result = result[:match.start()] + alt + result[match.end():]
            continue

        data = cache_path.read_bytes()

        # Per-image size limit
        if len(data) > _IMAGE_MAX_RAW:
            print(f"gmail: warning: image circ:{circ_hash} could not be resolved (exceeds {_IMAGE_MAX_RAW} byte limit: {len(data)} bytes)", file=sys.stderr)
            result = result[:match.start()] + alt + result[match.end():]
            continue

        mime = _detect_mime(data)
        if not mime:
            print(f"gmail: warning: image circ:{circ_hash} could not be resolved (unrecognized image format)", file=sys.stderr)
            result = result[:match.start()] + alt + result[match.end():]
            continue

        b64 = base64.b64encode(data).decode('ascii')

        # Total budget check
        if cumulative_b64 + len(b64) > _IMAGE_TOTAL_B64:
            print(f"gmail: warning: image circ:{circ_hash} could not be resolved (cumulative base64 budget exceeded)", file=sys.stderr)
            result = result[:match.start()] + alt + result[match.end():]
            continue

        cumulative_b64 += len(b64)
        data_uri = f'data:{mime};base64,{b64}'
        img_md = f'![{alt}]({data_uri})'
        result = result[:match.start()] + img_md + result[match.end():]

    return result


