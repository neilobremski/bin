#!/usr/bin/env bash
# mqtt-pub — publish to MQTT using env vars for broker config.
# Reads: MQTT_HOST, MQTT_PORT, MQTT_USER, MQTT_PASS
# All other args passed through to mosquitto_pub.
#
# Usage: mqtt-pub -t topic -m "message" [-r]

set -euo pipefail

args=(-h "${MQTT_HOST:-localhost}" -p "${MQTT_PORT:-1883}")
[ -n "${MQTT_USER:-}" ] && args+=(-u "$MQTT_USER")
[ -n "${MQTT_PASS:-}" ] && args+=(-P "$MQTT_PASS")
[ "${MQTT_PORT:-1883}" = "8883" ] && args+=(--capath /etc/ssl/certs)

exec mosquitto_pub "${args[@]}" "$@"
