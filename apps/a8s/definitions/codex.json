{
  "description": "Codex CLI default — workspace-write sandbox via --full-auto, resumes most recent.",
  "invoke": [
    "codex", "exec",
    "resume", "--last",
    "--full-auto",
    "--skip-git-repo-check",
    "$PROMPT"
  ],
  "invokeFresh": [
    "codex", "exec",
    "--full-auto",
    "--skip-git-repo-check",
    "$PROMPT"
  ],
  "invokeUnrestricted": [
    "codex", "exec",
    "resume", "--last",
    "--dangerously-bypass-approvals-and-sandbox",
    "--skip-git-repo-check",
    "$PROMPT"
  ],
  "invokeUnrestrictedFresh": [
    "codex", "exec",
    "--dangerously-bypass-approvals-and-sandbox",
    "--skip-git-repo-check",
    "$PROMPT"
  ],
  "promptMessage": "{sender} tells you ({recipient}): {message}",
  "promptMessageAlias": "{sender} tells you ({recipient}) and {others_count} others on the {alias} alias: {message}"
}
