#!/usr/bin/env python3
"""Synchronous CLI for hippocampus testing. No stimulus protocol needed.

Usage:
    memories store "some content" [--importance 5] [--category general]
    memories search "query" [--limit 10]
    memories recall [--limit 5]
    memories stats
    memories entity list
    memories entity get <id>
    memories entity create <id> <name> [--type thing] [--summary ""]
"""
import argparse
import json
import sqlite3
import sys
from pathlib import Path

# Add src to path
SRC = Path(__file__).resolve().parent.parent / "src"
sys.path.insert(0, str(SRC))

from constants import DB_PATH
from schema import init_db
from storage import store_and_check
from retrieval import search, recent, by_importance, stats
from entities import list_entities, get_entity_detail, create_entity


def open_db():
    db_path = Path(DB_PATH)
    db_path.parent.mkdir(parents=True, exist_ok=True)
    db = sqlite3.connect(str(db_path))
    init_db(db)
    return db


def cmd_store(args):
    db = open_db()
    mid = store_and_check(db, args.content, args.importance, args.category,
                          source="cli")
    db.commit()
    db.close()
    if mid:
        print(json.dumps({"stored": True, "id": mid}))
    else:
        print(json.dumps({"stored": False, "reason": "rejected or duplicate"}))


def cmd_search(args):
    db = open_db()
    results = search(db, args.query, limit=args.limit)
    db.commit()
    db.close()
    rows = []
    for r in results:
        rows.append({
            "id": r[0], "content": r[1], "importance": r[2],
            "category": r[3], "created_at": r[5],
        })
    print(json.dumps(rows, indent=2, default=str))


def cmd_recall(args):
    db = open_db()
    recent_rows = recent(db, limit=args.limit)
    important_rows = by_importance(db, limit=args.limit)

    seen = set()
    rows = []
    for r in list(important_rows) + list(recent_rows):
        if r[0] not in seen:
            seen.add(r[0])
            rows.append({
                "id": r[0], "content": r[1], "importance": r[2],
                "category": r[3], "created_at": r[5],
            })
    db.close()
    print(json.dumps(rows, indent=2, default=str))


def cmd_stats(args):
    db = open_db()
    s = stats(db)
    db.close()
    print(json.dumps(s, indent=2))


def cmd_entity_list(args):
    db = open_db()
    entities = list_entities(db)
    db.close()
    print(json.dumps(entities, indent=2, default=str))


def cmd_entity_get(args):
    db = open_db()
    detail = get_entity_detail(db, args.entity_id)
    db.close()
    if detail:
        print(json.dumps(detail, indent=2, default=str))
    else:
        print(json.dumps({"error": "not found"}))
        sys.exit(1)


def cmd_entity_create(args):
    db = open_db()
    ok = create_entity(db, args.entity_id, args.name,
                       entity_type=args.type, summary=args.summary)
    db.commit()
    db.close()
    print(json.dumps({"created": ok}))


def main():
    parser = argparse.ArgumentParser(prog="memories",
                                     description="Hippocampus CLI")
    sub = parser.add_subparsers(dest="command")

    # store
    p_store = sub.add_parser("store", help="Store a memory")
    p_store.add_argument("content")
    p_store.add_argument("--importance", type=int, default=5)
    p_store.add_argument("--category", default="general")
    p_store.set_defaults(func=cmd_store)

    # search
    p_search = sub.add_parser("search", help="Search memories")
    p_search.add_argument("query")
    p_search.add_argument("--limit", type=int, default=10)
    p_search.set_defaults(func=cmd_search)

    # recall
    p_recall = sub.add_parser("recall", help="Recall recent + important")
    p_recall.add_argument("--limit", type=int, default=5)
    p_recall.set_defaults(func=cmd_recall)

    # stats
    p_stats = sub.add_parser("stats", help="Memory statistics")
    p_stats.set_defaults(func=cmd_stats)

    # entity
    p_entity = sub.add_parser("entity", help="Entity management")
    entity_sub = p_entity.add_subparsers(dest="entity_command")

    p_el = entity_sub.add_parser("list", help="List entities")
    p_el.set_defaults(func=cmd_entity_list)

    p_eg = entity_sub.add_parser("get", help="Get entity detail")
    p_eg.add_argument("entity_id")
    p_eg.set_defaults(func=cmd_entity_get)

    p_ec = entity_sub.add_parser("create", help="Create entity")
    p_ec.add_argument("entity_id")
    p_ec.add_argument("name")
    p_ec.add_argument("--type", default="thing")
    p_ec.add_argument("--summary", default="")
    p_ec.set_defaults(func=cmd_entity_create)

    args = parser.parse_args()
    if not hasattr(args, "func"):
        parser.print_help()
        sys.exit(1)
    args.func(args)


if __name__ == "__main__":
    main()
