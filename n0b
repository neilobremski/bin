#!/usr/bin/env bash
echo `# <#` >/dev/null

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec python3 "$SCRIPT_DIR/apps/n0b/n0b.py" "$@"
#> > $null

$ScriptPath = $PSCommandPath
if (-not $ScriptPath) {
    $ScriptPath = $MyInvocation.MyCommand.Path
}
if (-not $ScriptPath) {
    $ScriptPath = Join-Path (Get-Location) "n0b"
}

$ScriptDir = Split-Path -Parent $ScriptPath
$N0bPath = Join-Path $ScriptDir "apps/n0b/n0b.py"

$Python = Get-Command python3 -ErrorAction SilentlyContinue
if ($Python) {
    & $Python.Source $N0bPath @args
    exit $LASTEXITCODE
}

$Python = Get-Command python -ErrorAction SilentlyContinue
if ($Python) {
    & $Python.Source $N0bPath @args
    exit $LASTEXITCODE
}

$Python = Get-Command py -ErrorAction SilentlyContinue
if ($Python) {
    & $Python.Source -3 $N0bPath @args
    exit $LASTEXITCODE
}

Write-Error "Could not find python3, python, or py on PATH."
exit 127
