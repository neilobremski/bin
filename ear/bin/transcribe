#!/usr/bin/env python3
"""Synchronous CLI for ear testing. No stimulus protocol needed.

Usage:
    transcribe <audio_file>
    transcribe <audio_file> --provider groq --language en --prompt "proper nouns"
    transcribe --json <audio_file>
    transcribe --detect
"""
import argparse
import json
import sys
from pathlib import Path

SRC = Path(__file__).resolve().parent.parent / "src"
sys.path.insert(0, str(SRC))

from transcribe import transcribe, get_provider, PROVIDERS


def main():
    parser = argparse.ArgumentParser(prog="transcribe",
                                     description="Transcribe audio via Whisper")
    parser.add_argument("audio_file", nargs="?", help="Path to audio file")
    parser.add_argument("--language", default="en", help="Language code (default: en)")
    parser.add_argument("--prompt", default=None, help="Prompt hint for proper nouns")
    parser.add_argument("--model", default=None, help="Whisper model override")
    parser.add_argument("--provider", default=None,
                        choices=PROVIDERS, help="Force provider")
    parser.add_argument("--json", action="store_true", dest="json_output",
                        help="Output full JSON response")
    parser.add_argument("--detect", action="store_true",
                        help="Detect and display available provider")

    args = parser.parse_args()

    if args.detect:
        provider = get_provider()
        if provider:
            print(f"provider: {provider}")
        else:
            print("no provider available", file=sys.stderr)
            sys.exit(1)
        return

    if not args.audio_file:
        parser.print_help()
        sys.exit(1)

    try:
        result = transcribe(args.audio_file, language=args.language,
                           prompt=args.prompt, model=args.model,
                           provider=args.provider)
    except RuntimeError as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(1)

    if args.json_output:
        print(json.dumps(result, indent=2))
    else:
        print(result.get("text", ""))


if __name__ == "__main__":
    main()
