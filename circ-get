#!/usr/bin/env bash
# circ-get — Retrieve a payload from the circulatory system.
#
# Usage: circ-get <hash> [output-file]
#
# Checks local cache first, falls back to Google Drive via gas CLI.

set -euo pipefail

LOCAL_DIR="${CIRC_DIR:-$HOME/.life/circ}"

if [ $# -lt 1 ]; then
  echo "Usage: circ-get <hash> [output-file]" >&2
  exit 1
fi

hash="$1"
output="${2:-}"

# Try local first (fast)
if [ -f "$LOCAL_DIR/$hash" ]; then
  if [ -n "$output" ]; then
    cp "$LOCAL_DIR/$hash" "$output"
  else
    cat "$LOCAL_DIR/$hash"
  fi
  exit 0
fi

# Fall back to Drive via gas CLI
if command -v gas >/dev/null 2>&1; then
  files=$(gas drive.list "query=title = 'circ-$hash'" count=1 2>/dev/null || echo '{}')
  fid=$(echo "$files" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['files'][0]['id'] if d.get('files') else '')" 2>/dev/null)

  if [ -n "$fid" ]; then
    data=$(gas drive.download "id=$fid" 2>/dev/null)
    # Extract base64 data and decode
    decoded=$(echo "$data" | python3 -c "import sys,json,base64; d=json.load(sys.stdin); sys.stdout.buffer.write(base64.b64decode(d['data']))" 2>/dev/null)

    # Cache locally for next time
    mkdir -p "$LOCAL_DIR"
    echo "$decoded" > "$LOCAL_DIR/$hash"

    if [ -n "$output" ]; then
      echo "$decoded" > "$output"
    else
      echo "$decoded"
    fi
    exit 0
  fi
fi

echo "error: payload not found: $hash" >&2
exit 1
