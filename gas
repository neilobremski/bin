# ── Parser ──────────────────────────────────────────────────────────────────

def build_parser():
    parser = argparse.ArgumentParser(
        prog="gas",
        description="CLI for the GAS Bridge — Gmail, Drive, Sheets, Calendar, Tasks, Contacts, Gemini.",
    )
    parser.add_argument("--jq", nargs="?", const=".", default=None,
                        help="(pre-parsed) jq filter applied to stdout JSON")

    sub = parser.add_subparsers(dest="group", help="Service group")

    # gmail
    gmail = sub.add_parser("gmail", help="Gmail: send/search/get/read/archive/reply/label/attachments + drafts")
    gmail_sub = gmail.add_subparsers(dest="command")

    p = gmail_sub.add_parser("send", help="Send a new email")
    p.add_argument("--to", required=True, help="Recipient address")
    p.add_argument("--subject", required=True, help="Subject line")
    p.add_argument("--body", help="Plain-text body (inline, @file, or -)")
    p.add_argument("--cc", help="CC address(es)")
    p.add_argument("--bcc", help="BCC address(es)")
    p.add_argument("--html", help="HTML body (inline, @file, or -)")
    p.add_argument("--reply-to", help="Reply-To address")
    p.set_defaults(func=cmd_gmail_send)

    p = gmail_sub.add_parser("search", help="Search threads (Gmail query syntax)")
    p.add_argument("--query", default="is:unread", help="Gmail query (default: is:unread)")
    p.add_argument("--count", type=int, default=10, help="Max threads to return (default: 10)")
    p.set_defaults(func=cmd_gmail_search)

    p = gmail_sub.add_parser("check", help="Alias for `search` (bridge-level alias)")
    p.add_argument("--query", default="is:unread", help="Gmail query (default: is:unread)")
    p.add_argument("--count", type=int, default=10, help="Max threads to return (default: 10)")
    p.set_defaults(func=cmd_gmail_check)

    p = gmail_sub.add_parser("get", help="Get full thread by ID")
    p.add_argument("--thread-id", required=True, help="Thread ID")
    p.set_defaults(func=cmd_gmail_get)

    p = gmail_sub.add_parser("read", help="Mark a thread as read")
    p.add_argument("--thread-id", required=True, help="Thread ID")
    p.set_defaults(func=cmd_gmail_read)

    p = gmail_sub.add_parser("archive", help="Mark read and archive a thread")
    p.add_argument("--thread-id", required=True, help="Thread ID")
    p.set_defaults(func=cmd_gmail_archive)

    p = gmail_sub.add_parser("reply", help="Reply to the latest message in a thread")
    p.add_argument("--thread-id", required=True, help="Thread ID")
    p.add_argument("--body", required=True, help="Reply body (inline, @file, or -)")
    p.add_argument("--html", help="HTML body (inline, @file, or -)")
    p.add_argument("--cc", help="CC address(es)")
    p.set_defaults(func=cmd_gmail_reply)

    p = gmail_sub.add_parser("label", help="Add or remove a label / star / unread on a thread")
    p.add_argument("--thread-id", required=True, help="Thread ID")
    p.add_argument("--add", help="Label to add (special: UNREAD, STARRED)")
    p.add_argument("--remove", help="Label to remove (special: UNREAD, STARRED)")
    p.set_defaults(func=cmd_gmail_label)

    p = gmail_sub.add_parser("attachments", help="List or save attachments from a message or thread")
    p.add_argument("--message-id", help="Message ID (or use --thread-id)")
    p.add_argument("--thread-id", help="Thread ID (use instead of --message-id)")
    p.add_argument("--save-to-drive", action="store_true", help="Also save attachments to Drive")
    p.add_argument("--folder-id", help="Drive folder ID for --save-to-drive")
    p.set_defaults(func=cmd_gmail_attachments)

    p = gmail_sub.add_parser("draft.create", help="Create a draft email")
    p.add_argument("--to", required=True, help="Recipient address")
    p.add_argument("--subject", help="Subject line")
    p.add_argument("--body", help="Plain-text body (inline, @file, or -)")
    p.add_argument("--html", help="HTML body (inline, @file, or -)")
    p.set_defaults(func=cmd_gmail_draft_create)

    p = gmail_sub.add_parser("draft.list", help="List drafts")
    p.add_argument("--count", type=int, default=10, help="Max drafts to return (default: 10)")
    p.set_defaults(func=cmd_gmail_draft_list)

    p = gmail_sub.add_parser("draft.get", help="Get a draft by ID")
    p.add_argument("--draft-id", required=True, help="Draft ID")
    p.set_defaults(func=cmd_gmail_draft_get)

    p = gmail_sub.add_parser("draft.send", help="Send a previously-created draft")
    p.add_argument("--draft-id", required=True, help="Draft ID")
    p.set_defaults(func=cmd_gmail_draft_send)

    p = gmail_sub.add_parser("draft.delete", help="Delete a draft")
    p.add_argument("--draft-id", required=True, help="Draft ID")
    p.set_defaults(func=cmd_gmail_draft_delete)

    # drive
    drive = sub.add_parser("drive", help="Drive: list/create/upload/upsert/download/delete/folders")
    drive_sub = drive.add_subparsers(dest="command")

    p = drive_sub.add_parser("list", help="List or search files and folders")
    p.add_argument("--query", help="Drive query (e.g. \"title contains 'foo'\")")
    p.add_argument("--count", type=int, default=10, help="Max items to return (default: 10)")
    p.add_argument("--folder-id", help="Restrict to a specific folder")
    p.set_defaults(func=cmd_drive_list)

    p = drive_sub.add_parser("create", help="Create a Doc / Sheet / folder / arbitrary file")
    p.add_argument("--name", required=True, help="File or folder name")
    p.add_argument("--type", default="document", choices=["document", "spreadsheet", "folder", "file"],
                   help="What to create (default: document)")
    p.add_argument("--content", help="Initial content for `file` type (inline, @file, -)")
    p.add_argument("--mime", help="MIME type for `file` type (default: text/plain)")
    p.add_argument("--folder-id", help="Parent folder (default: My Drive root)")
    p.set_defaults(func=cmd_drive_create)

    p = drive_sub.add_parser("upload", help="Upload a file (`@/path` or `-` for stdin)")
    p.add_argument("--name", required=True, help="Filename in Drive")
    p.add_argument("--data-base64", required=True, help="`@/path/to/file`, `-` for stdin, or pre-encoded base64")
    p.add_argument("--mime", help="MIME type (default: application/octet-stream)")
    p.add_argument("--folder-id", help="Parent folder")
    p.set_defaults(func=cmd_drive_upload)

    p = drive_sub.add_parser("upsert", help="Upload, replacing any existing file of the same name in the folder")
    p.add_argument("--name", required=True, help="Filename in Drive")
    p.add_argument("--data-base64", required=True, help="`@/path/to/file`, `-` for stdin, or pre-encoded base64")
    p.add_argument("--mime", help="MIME type (default: application/octet-stream)")
    p.add_argument("--folder-id", help="Parent folder")
    p.set_defaults(func=cmd_drive_upsert)

    p = drive_sub.add_parser("download", help="Download a file as base64")
    p.add_argument("--id", help="File ID")
    p.add_argument("--name", help="Filename to look up (newest match wins)")
    p.set_defaults(func=cmd_drive_download)

    p = drive_sub.add_parser("delete", help="Trash a file or folder by ID")
    p.add_argument("--id", required=True, help="File or folder ID")
    p.set_defaults(func=cmd_drive_delete)

    p = drive_sub.add_parser("folders", help="List or create folders")
    p.add_argument("--query", help="Folder name query")
    p.add_argument("--count", type=int, default=20, help="Max folders to list (default: 20)")
    p.add_argument("--create", help="Create a new folder with this name")
    p.add_argument("--parent-id", help="Parent folder for --create")
    p.set_defaults(func=cmd_drive_folders)

    # sheets
    sheets = sub.add_parser("sheets", help="Sheets: read/append/create/update")
    sheets_sub = sheets.add_subparsers(dest="command")

    p = sheets_sub.add_parser("read", help="Read a range from a spreadsheet")
    p.add_argument("--spreadsheet-id", help="Spreadsheet ID")
    p.add_argument("--name", help="Spreadsheet name (alternative to --spreadsheet-id)")
    p.add_argument("--range", default="Sheet1!A1:Z100", help="A1 range (default: Sheet1!A1:Z100)")
    p.set_defaults(func=cmd_sheets_read)

    p = sheets_sub.add_parser("append", help="Append rows to a sheet")
    p.add_argument("--spreadsheet-id", help="Spreadsheet ID")
    p.add_argument("--name", help="Spreadsheet name")
    p.add_argument("--sheet", default="Sheet1", help="Tab name (default: Sheet1)")
    p.add_argument("--rows", required=True, help="Rows as 2D JSON array (inline, @file, or -)")
    p.set_defaults(func=cmd_sheets_append)

    p = sheets_sub.add_parser("create", help="Create a new spreadsheet")
    p.add_argument("--name", required=True, help="Spreadsheet name")
    p.add_argument("--headers", help="Header row as 1D JSON array (inline, @file, or -)")
    p.set_defaults(func=cmd_sheets_create)

    p = sheets_sub.add_parser("update", help="Set values in a range")
    p.add_argument("--spreadsheet-id", help="Spreadsheet ID")
    p.add_argument("--name", help="Spreadsheet name")
    p.add_argument("--range", required=True, help="A1 range to overwrite")
    p.add_argument("--values", required=True, help="2D JSON array of values (inline, @file, or -)")
    p.set_defaults(func=cmd_sheets_update)

    # calendar
    cal = sub.add_parser("calendar", help="Calendar: list/create/delete + list calendars")
    cal_sub = cal.add_subparsers(dest="command")

    p = cal_sub.add_parser("list", help="List upcoming events")
    p.add_argument("--days", type=int, default=7, help="Window size in days (default: 7)")
    p.add_argument("--calendar-id", help="Specific calendar ID (default: primary)")
    p.set_defaults(func=cmd_calendar_list)

    p = cal_sub.add_parser("create", help="Create a calendar event")
    p.add_argument("--title", required=True, help="Event title")
    p.add_argument("--start", required=True, help="Start time (ISO 8601)")
