def extract_jq(argv):
    """Pre-parse `--jq <expr>` from argv. Returns (jq_expr_or_None, remaining_argv).
    Recognizes both `--jq EXPR` and `--jq=EXPR`. If `--jq` is the last token,
    defaults to `.`."""
    out = []
    jq_expr = None
    i = 0
    while i < len(argv):
        tok = argv[i]
        if tok == "--jq":
            if i + 1 < len(argv) and not argv[i + 1].startswith("-"):
                jq_expr = argv[i + 1]
                i += 2
            else:
                jq_expr = "."
                i += 1
            continue
        if tok.startswith("--jq="):
            jq_expr = tok[len("--jq="):] or "."
            i += 1
            continue
        out.append(tok)
        i += 1
    return jq_expr, out


def main():
    global JQ_ARGS
    argv = sys.argv[1:]
    jq_expr, remaining = extract_jq(argv)
    if jq_expr is not None:
        JQ_ARGS = [jq_expr]

    parser = build_parser()
    if not remaining:
        parser.print_help(file=sys.stderr)
        sys.exit(1)

    args = parser.parse_args(remaining)

    if not hasattr(args, "func"):
        # Group with no subcommand
        if args.group:
            sub_help = parser._subparsers._group_actions[0].choices.get(args.group)
            if sub_help:
                sub_help.print_help(file=sys.stderr)
        else:
            parser.print_help(file=sys.stderr)
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    main()
