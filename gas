#!/usr/bin/env python3
"""gas — CLI for the GAS Bridge.

Hierarchical argparse interface mirroring the deployed bridge's HANDLERS map.
Run `gas --help` for the full subcommand tree, `gas <group> --help` for a
group, and `gas <group> <command> --help` for a specific action.

Auth: GAS_BRIDGE_URL and GAS_BRIDGE_KEY via env vars or ~/lib/gas-bridge-{url,key}.txt
(resolved through the `local-secret` helper).

Output: JSON on stdout (pretty when isatty, compact when piped). Status and
errors on stderr. Append `--jq <expr>` anywhere to pipe stdout JSON through jq.

Long-text args (`--body`, `--query`, `--prompt`, etc.) accept three forms:
  inline string, `@/path/to/file` to read from a file, or `-` to read stdin.
Binary blobs (`--data-base64`) accept `@/path` (read + base64-encode the
file) or `-` (base64-encode stdin).
"""
import argparse
import base64
import json
import os
import subprocess
import sys
import urllib.error
import urllib.request
from datetime import datetime
from pathlib import Path


JQ_ARGS = None
BRIDGE_URL = None
BRIDGE_KEY = None


def err(msg):
    print(f"gas: {msg}", file=sys.stderr)


def info(msg):
    print(f"  {msg}", file=sys.stderr)


def json_out(obj):
    pretty = sys.stdout.isatty()
    text = json.dumps(obj, indent=2 if pretty else None)
    if JQ_ARGS is not None:
        proc = subprocess.run(["jq"] + JQ_ARGS, input=text, text=True)
        if proc.returncode != 0:
            sys.exit(proc.returncode)
    else:
        print(text)


def local_secret(name):
    try:
        out = subprocess.check_output(
            ["local-secret", name], text=True, stderr=subprocess.DEVNULL
        )
        return out.strip()
    except (FileNotFoundError, subprocess.CalledProcessError):
        return ""


def load_credentials():
    global BRIDGE_URL, BRIDGE_KEY
    if BRIDGE_URL and BRIDGE_KEY:
        return
    BRIDGE_URL = local_secret("GAS_BRIDGE_URL")
    BRIDGE_KEY = local_secret("GAS_BRIDGE_KEY")
    if not BRIDGE_URL or not BRIDGE_KEY:
        err("missing credentials.")
        info("set GAS_BRIDGE_URL and GAS_BRIDGE_KEY env vars,")
        info("or write ~/lib/gas-bridge-url.txt and ~/lib/gas-bridge-key.txt")
        sys.exit(1)


def read_text(value):
    """Three-tier text input: inline / @file / - (stdin)."""
    if value is None:
        return None
    if value == "-":
        if sys.stdin.isatty():
            err("expected text on stdin (got terminal)")
            sys.exit(1)
        return sys.stdin.read()
    if value.startswith("@"):
        path = value[1:]
        if not os.path.isfile(path):
            err(f"file not found: {path}")
            sys.exit(1)
        with open(path) as f:
            return f.read()
    return value


def read_bytes_b64(value):
    """Read raw bytes (file or stdin) and base64-encode. `-` for stdin, `@path`
    or bare path for a file. Plain strings without the prefix are still
    accepted as already-encoded base64 (passthrough)."""
    if value is None:
        return None
    if value == "-":
        if sys.stdin.isatty():
            err("expected binary on stdin (got terminal)")
            sys.exit(1)
        return base64.b64encode(sys.stdin.buffer.read()).decode()
    if value.startswith("@"):
        path = value[1:]
        if not os.path.isfile(path):
            err(f"file not found: {path}")
            sys.exit(1)
        with open(path, "rb") as f:
            return base64.b64encode(f.read()).decode()
    return value


def parse_kv(items):
    """Convert a list of KEY=VALUE strings into a dict. Used for --header / --param."""
    result = {}
    for item in items or []:
        if "=" not in item:
            err(f"expected KEY=VALUE: {item}")
            sys.exit(1)
        k, _, v = item.partition("=")
        result[k] = v
    return result


def log_call(action, summary, snippet):
    try:
        log_dir = Path.home() / ".gas" / "logs"
        log_dir.mkdir(parents=True, exist_ok=True)
        now = datetime.now()
        path = log_dir / f"{now:%Y-%m-%d}.txt"
        line = f"{now:%H:%M:%S} {action} {summary} -> {snippet}\n"
        with open(path, "a") as f:
            f.write(line)
    except Exception:
        pass


def snippet_of(body):
    try:
        obj = json.loads(body)
    except (json.JSONDecodeError, TypeError):
        return "ok"
    if isinstance(obj, dict):
        if "error" in obj:
            return f"error: {str(obj['error'])[:80]}"
        if "status" in obj:
            return f"status: {obj['status']}"
        if "count" in obj:
            return f"ok ({obj['count']} items)"
    if isinstance(obj, list):
        return f"list[{len(obj)}]"
    return "ok"


def summarize_payload(payload):
    keys = [k for k in payload if k not in ("action", "key")]
    return ",".join(keys) if keys else ""


def call(action, payload):
    """POST to the bridge. payload is action-specific; auth is added here."""
    load_credentials()
    body = {"action": action, "key": BRIDGE_KEY}
    body.update({k: v for k, v in payload.items() if v is not None})

    data = json.dumps(body).encode()
    req = urllib.request.Request(
        BRIDGE_URL,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    summary = summarize_payload(body)

    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            text = resp.read().decode()
    except urllib.error.HTTPError as e:
        err_body = e.read().decode()[:500] if e.fp else ""
        log_call(action, summary, f"HTTP {e.code}")
        err(f"HTTP {e.code} from bridge")
        if err_body:
            info(err_body)
        sys.exit(1)
    except urllib.error.URLError as e:
        log_call(action, summary, f"network error: {e.reason}")
        err(f"network error: {e.reason}")
        sys.exit(1)
    except Exception as e:
        log_call(action, summary, f"exception: {str(e)[:80]}")
        err(f"unexpected error: {e}")
        sys.exit(1)

    log_call(action, summary, snippet_of(text))
    try:
        parsed = json.loads(text)
    except json.JSONDecodeError:
        err("non-JSON response from bridge")
        info(text[:300])
        sys.exit(1)

    if isinstance(parsed, dict) and "error" in parsed:
        err(f"bridge error: {parsed['error']}")
        json_out(parsed)
        sys.exit(1)
    json_out(parsed)


